# Clerk (public key only on the client — get from https://dashboard.clerk.com/last-active?path=api-keys)
VITE_CLERK_PUBLISHABLE_KEY=

# Supabase (Dashboard → Project Settings → Data API → Project API Keys → publishable / default key)
# Public — RLS enforced. Never put the service_role secret here.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional — only if you still set the old env name from legacy docs/UI
# VITE_SUPABASE_ANON_KEY=
